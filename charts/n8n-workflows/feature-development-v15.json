      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        450,
        400
      ],
      "parameters": {
        "jsCode": "const body = $input.first().json.body || $input.first().json;\nreturn [{\n  json: {\n    req_id: body.req_id || 'REQ-TEST-01',\n    title: body.title || 'New Feature',\n    description: body.description || '',\n    scope: body.scope || 'backend'\n  }\n}];"
      }
