    {
      "parameters": {
        "jsCode": "// Phase 5: AI 验收\nconst input = $input.first().json;\n\n// 模拟加载验收规格\nconst acCases = [\n  { id: 'AC-01', title: '核心功能验收', status: 'passed' },\n  { id: 'AC-02', title: '边界条件验收', status: 'passed' },\n  { id: 'AC-03', title: '异常处理验收', status: 'passed' },\n  { id: 'AC-04', title: '并发场景验收', status: 'passed' },\n  { id: 'AC-05', title: '性能基准验收', status: 'passed' },\n  { id: 'AC-06', title: '安全合规验收', status: 'passed' }\n];\n\nconst allPassed = acCases.every(c => c.status === 'passed');\n\nreturn [{\n  json: {\n    ...input,\n    phase: 'ai_acceptance',\n    test_results: {\n      ...input.test_results,\n      acceptance: {\n        cases: acCases,\n        passed: acCases.filter(c => c.status === 'passed').length,\n        failed: acCases.filter(c => c.status === 'failed').length,\n        total: acCases.length\n      }\n    },\n    acceptance_passed: allPassed\n  }\n}];"
      },
      "id": "run-ai-acceptance",
