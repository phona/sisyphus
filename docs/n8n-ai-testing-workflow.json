    {
      "parameters": {
        "jsCode": "// Phase 4: 质量关卡\nconst input = $input.first().json;\n\n// 模拟 Linter 检查\nconst lintResult = {\n  passed: true,\n  tool: 'golangci-lint',\n  issues: 0,\n  duration: '5s'\n};\n\n// 模拟 AI Code Review\nconst aiReviewResult = {\n  passed: true,\n  model: 'claude-3-5-sonnet',\n  comments: [],\n  score: 95,\n  duration: '30s'\n};\n\nreturn [{\n  json: {\n    ...input,\n    phase: 'quality_gate',\n    quality_gate: {\n      lint: lintResult,\n      ai_review: aiReviewResult\n    },\n    quality_passed: lintResult.passed && aiReviewResult.passed\n  }\n}];"
      },
      "id": "run-quality-gate",
      "name": "运行质量关卡",
