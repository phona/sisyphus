    {
      "parameters": {
        "jsCode": "// 初始化需求上下文\nconst reqId = $input.first().json.req_id || 'REQ-01';\nconst reqTitle = $input.first().json.title || '新功能需求';\n\nreturn [{\n  json: {\n    req_id: reqId,\n    title: reqTitle,\n    phase: 'init',\n    status: 'started',\n    timestamp: new Date().toISOString(),\n    specs: {\n      dev: null,\n      contract: null,\n      acceptance: null\n    },\n    branches: {\n      dev: `dev/${reqId}`,\n      test: `test/${reqId}`,\n      ac: `ac/${reqId}`\n    },\n    test_results: {\n      unit: null,\n      contract: null,\n      acceptance: null\n    },\n    quality_gate: {\n      lint: null,\n      ai_review: null\n    }\n  }\n}];"
      },
      "id": "init-context",
      "name": "初始化需求上下文",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [450, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://gitea-http.sisyphus.svc.cluster.local:3000/api/v1/repos/gitea_admin/{{$json.req_id}}-specs/issues",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "title",
              "value": "[Phase 0] 接口契约设计 - {{$json.req_id}}"
            },
            {
              "name": "body",
              "value": "## 契约设计任务\n\n**需求ID**: {{$json.req_id}}\n**需求标题**: {{$json.title}}\n\n### 任务清单\n- [ ] 后端主导设计 API 契约\n- [ ] 前端确认接口满足 UI 需求\n- [ ] 测试确认契约可测试、边界清晰\n\n### 输出物\n- `specs/{{$json.req_id}}/contract.spec.yaml`\n\n### 检查点\n- [ ] 请求/响应 Schema 完整\n- [ ] 边界值定义清晰\n- [ ] 错误码规范统一\n\n@backend @frontend @qa"
            }
          ]
        }
      },
      "id": "create-contract-issue",
      "name": "创建契约设计任务",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [650, 200]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "http://gitea-http.sisyphus.svc.cluster.local:3000/api/v1/repos/gitea_admin/{{$json.req_id}}-specs/contents/specs/{{$json.req_id}}/contract.spec.yaml",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth"
      },
      "id": "check-contract-spec",
      "name": "检查契约规格",
