      "parameters": {
        "jsCode": "// Phase 3: TDD + 契约 Battle\nconst input = $input.first().json;\n\n// 模拟运行单元测试\nconst unitTestResult = {\n  passed: true,\n  coverage: 85,\n  total: 45,\n  failed: 0,\n  duration: '12s'\n};\n\n// 模拟运行契约测试\nconst contractTestResult = {\n  passed: true,\n  total: 12,\n  failed: 0,\n  duration: '8s'\n};\n\nreturn [{\n  json: {\n    ...input,\n    phase: 'tdd_battle',\n    test_results: {\n      unit: unitTestResult,\n      contract: contractTestResult\n    },\n    battle_passed: unitTestResult.passed && contractTestResult.passed\n  }\n}];"
      },
      "id": "run-tdd-battle",
      "name": "运行 TDD Battle",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2650, 200]
