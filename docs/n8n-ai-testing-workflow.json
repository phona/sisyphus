    {
      "parameters": {
        "jsCode": "// 解析状态文件检查三方是否都 done\nconst input = $input.first().json;\n\n// 模拟从 Gitea 获取的状态\nconst mockStatus = {\n  dev: { status: 'done', completed_at: '2026-04-06T10:00:00Z', unit_test_coverage: '85%' },\n  test: { status: 'done', completed_at: '2026-04-06T11:00:00Z', contract_test_count: 12 },\n  ac: { status: 'done', completed_at: '2026-04-06T12:00:00Z', acceptance_cases_count: 6 }\n};\n\nconst allDone = mockStatus.dev.status === 'done' && \n                  mockStatus.test.status === 'done' && \n                  mockStatus.ac.status === 'done';\n\nreturn [{\n  json: {\n    ...input,\n    phase: 'merge_gate',\n    status_check: mockStatus,\n    all_done: allDone\n  }\n}];"
      },
      "id": "check-all-done",
      "name": "检查完成状态",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2050, 300]
