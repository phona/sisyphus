    {
      "parameters": {
        "jsCode": "// Phase 1: OpenSpec 拆分\nconst input = $input.first().json;\n\n// 模拟 AI 拆分规格\nconst devSpec = `# DEV-SPEC: ${input.title}\n\n## 功能清单\n- [ ] FR-01: 核心功能实现\n- [ ] FR-02: 边界处理\n\n## 数据模型\n\`\`\`go\ntype Entity struct {\n    ID string\n    // ...\n}\n\`\`\`\n\n## 实现注意事项\n1. 注意并发安全\n2. 完整状态机设计\n`;\n\nconst acSpec = {\n  version: '1.0',\n  req_id: input.req_id,\n  acceptance_criteria: [\n    {\n      id: `${input.req_id}-AC-01`,\n      title: '核心功能验收',\n      given: ['系统正常运行'],\n      when: [{ action: 'trigger_feature', params: {} }],\n      then: [{ assert: 'feature.status == \"success\"' }]\n    }\n  ]\n};\n\nreturn [{\n  json: {\n    ...input,\n    phase: 'spec_split',\n    specs: {\n      dev: devSpec,\n      contract: '已存在',\n      acceptance: acSpec\n    }\n  }\n}];"
      },
      "id": "spec-split",
      "name": "OpenSpec 拆分",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1050, 350]
    },
    {
      "parameters": {
        "jsCode": "// 创建三个并行开发分支\nconst input = $input.first().json;\nconst branches = ['dev', 'test', 'ac'];\n\nreturn branches.map(type => ({\n  json: {\n    ...input,\n    branch_type: type,\n    branch_name: `${type}/${input.req_id}`,\n    assignee: type === 'dev' ? 'developer' : type === 'test' ? 'tester' : 'acceptance'\n  }\n}));"
      },
      "id": "create-branches",
      "name": "创建并行分支",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1250, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://gitea-http.sisyphus.svc.cluster.local:3000/api/v1/repos/gitea_admin/ttpos-server-go/pulls",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "title",
              "value": "[{{$json.branch_type}}] {{$json.req_id}}: {{$json.title}}"
            },
            {
              "name": "head",
              "value": "={{$json.branch_name}}"
            },
            {
              "name": "base",
              "value": "feature/{{$json.req_id}}"
            },
            {
              "name": "body",
              "value": "## {{$json.branch_type === 'dev' ? '开发' : $json.branch_type === 'test' ? '测试' : '验收'}}分支\n\n**需求ID**: {{$json.req_id}}\n**负责人**: @{{$json.assignee}}\n\n### 任务\n{{$json.branch_type === 'dev' ? '- [ ] 编写单元测试 (TDD)' : $json.branch_type === 'test' ? '- [ ] 编写契约测试' : '- [ ] 编写验收用例'}}\n{{$json.branch_type === 'dev' ? '- [ ] 实现功能代码' : ''}}\n\n### 完成标准\n{{$json.branch_type === 'dev' ? '- 单元测试覆盖率 ≥ 80%' : $json.branch_type === 'test' ? '- 契约测试全部通过' : '- 验收用例可被 AI 执行'}}"
            }
          ]
        }
      },
